# ─────────────────────────────────────────────────────────────────────────────
# Research Agent — environment
# Copy to `.env` (in this folder) and add your key.
# Unlike the travel agent, this needs ONLY an Anthropic key — web search and
# page fetching run server-side on Anthropic's infrastructure (no extra APIs).
# ─────────────────────────────────────────────────────────────────────────────

# Required. https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model (optional). Defaults to claude-opus-4-8.
ANTHROPIC_MODEL=claude-opus-4-8

# Effort for the agent loop: low | medium | high | xhigh | max. Default high.
# Deep mode bumps this one notch by default.
RESEARCH_EFFORT=high
