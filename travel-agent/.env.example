# ─────────────────────────────────────────────────────────────────────────────
# AI Travel Agent — environment variables
# Copy this file to `.env` (in the repo root) and fill in the keys you have.
# Every source degrades gracefully: a missing key disables only that one source,
# it never crashes the search. Start with ANTHROPIC_API_KEY — the agent runs
# with just that (other sources will report "not configured" until you add keys).
# ─────────────────────────────────────────────────────────────────────────────

# Required: the AI agent itself. https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model id (optional). Defaults to claude-sonnet-4-6.
# Swap to claude-opus-4-8 for stronger synthesis at higher cost.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Flights ──────────────────────────────────────────────────────────────────
# Primary: Kiwi.com Tequila API. https://tequila.kiwi.com (free tier available)
KIWI_TEQUILA_API_KEY=

# ── Hotels & Activities (RapidAPI) ───────────────────────────────────────────
# One RapidAPI key unlocks the Booking.com (hotels) + Viator/Tours (activities)
# endpoints. https://rapidapi.com
RAPIDAPI_KEY=
# Host slugs for the specific RapidAPI products you subscribed to.
RAPIDAPI_BOOKING_HOST=booking-com.p.rapidapi.com
RAPIDAPI_ACTIVITIES_HOST=travel-advisor.p.rapidapi.com

# ── Activities (Viator direct, optional alternative to RapidAPI) ─────────────
# https://api.viator.com/partner
VIATOR_API_KEY=

# ── Event tickets (SeatGeek + StubHub) ───────────────────────────────────────
# SeatGeek: free, only a client id is needed. https://seatgeek.com/account/develop
SEATGEEK_CLIENT_ID=
SEATGEEK_CLIENT_SECRET=
# StubHub: partner program — OAuth client-credentials. https://developer.stubhub.com
# Best-effort: requires approved partner access. Leave blank to use SeatGeek only.
STUBHUB_CLIENT_ID=
STUBHUB_CLIENT_SECRET=

# ── Scrapers (Airbnb / VRBO / Kayak cars) ────────────────────────────────────
# No keys required — these use Playwright. Set HEADLESS=false to watch the
# browser and debug when a scraper returns 0 results (bot detection, layout
# changes, etc.). Defaults to true.
HEADLESS=true
# Milliseconds before an idle browser context is auto-closed. Default 120000.
SCRAPER_IDLE_TIMEOUT_MS=120000

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# Comma-separated allowed origins for CORS. Default allows the Vite dev server.
CORS_ORIGIN=http://localhost:5173
